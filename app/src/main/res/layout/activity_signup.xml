<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Signup"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Signup"
        android:textSize="38sp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:textColor="@color/orange"
        android:background="@drawable/shape"
        android:padding="12dp"
        android:layout_marginTop="20dp"/>

<!--    Below is a cardview -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="25dp"
        app:cardElevation="10dp"
        android:layout_margin="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@color/blue">

<!--            Below is the EditText for username-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:hint="👤 Enter your username"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:padding="8dp"/>

            <!--            Below is the EditText for email-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:hint="📧 Enter your email address"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:id="@+id/email"
                android:inputType="textEmailAddress"
                android:layout_margin="8dp"
                android:padding="10dp"/>

            <!--            Below is the EditText for password-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:hint="🔑 Enter your password"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:id="@+id/password"
                android:inputType="textPassword"
                android:layout_margin="8dp"
                android:padding="8dp"/>

            <!--            Below is the EditText for phone-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:hint="☎️ Enter your phone number"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:id="@+id/phone"
                android:inputType="number"
                android:layout_margin="8dp"
                android:padding="8dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Signup"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginTop="10dp"
                android:textColor="@color/white"
                android:backgroundTint="@color/violet"
                android:id="@+id/signupBtn" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dont have an account? Signin"
                android:textAlignment="center"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:layout_marginTop="15sp"
                android:id="@+id/signintxt"/>


        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>