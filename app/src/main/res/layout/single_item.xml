<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

<!--    Below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"
        android:layout_margin="10dp"
        app:cardMaxElevation="15dp"
        app:cardCornerRadius="25dp">

<!--        Below  is another linearlayout that dictates how the contents will be aligned -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="@color/white">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_name"
                android:text="Product Name"
                android:textColor="@color/violet"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textAlignment="center"/>

<!--            Below is our product_image -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="250sp"
                android:id="@+id/product_photo"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitXY"
                android:layout_marginRight="20sp"
                android:layout_marginLeft="20sp"

                android:layout_marginTop="5dp"/>

<!--            Below is a textview for the product_cost-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_cost"
                android:text="Kes 500"
                android:layout_marginTop="5dp"
                android:textSize="25dp"
                android:textColor="@color/violet"
                android:layout_marginLeft="10dp"
                android:textStyle="bold"/>

<!--            Below is a textview for the product_description-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_description"
                android:text="The product description will appear here"
                android:textSize="20sp"
                android:textColor="@color/blue"
                android:textStyle="italic"
                android:layout_marginTop="3dp"/>

<!--            Below is the purchase now button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btnPurchase"
                android:text="PURCHASE NOW!"
                android:textSize="20dp"
                android:backgroundTint="@color/orange"
                android:layout_marginTop="5dp"
                android:layout_marginLeft="70dp"
                android:layout_marginRight="70dp"/>
        </LinearLayout>


    </androidx.cardview.widget.CardView>

</LinearLayout>